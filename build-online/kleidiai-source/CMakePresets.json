{
  "version": 3,
  "configurePresets": [
    {
      "name": "default-config",
      "binaryDir": "build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-Werror",
        "CMAKE_CXX_FLAGS": "-Werror",
        "KLEIDIAI_BUILD_TESTS": "ON",
        "KLEIDIAI_BUILD_BENCHMARK": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-build",
      "configurePreset": "default-config"
    }
  ]
}
